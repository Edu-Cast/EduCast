    "Python", "Java", "JavaScript", "SQL", "Docker", "Kubernetes"
  ],

  "educational_markers": [
    "теорема", "формула", "определение", "пример", "задача", "лекция",
    "закон", "функция", "уравнение", "рассмотрим", "изучаем", "доказательство",
    "python", "git", "алгоритм", "класс", "переменная", "база данных",
